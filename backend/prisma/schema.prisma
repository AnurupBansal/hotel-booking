generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id            String    @id @default(uuid())
  name          String
  description   String
  pricePerNight Int
  maxGuests     Int
  images        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]

  @@index([pricePerNight])
  @@index([maxGuests])
  @@map("rooms")
}

model Booking {
  id         String   @id @default(uuid())
  roomId     String
  guestName  String   @map("guest_name")
  guestPhone String   @map("guest_phone")
  guestEmail String?  @map("guest_email")
  checkIn    DateTime
  checkOut   DateTime
  amountPaid Int      @map("amount_paid")
  status     String
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([roomId])
  @@index([guestPhone])
  @@index([checkIn, checkOut])
  @@index([status])
  @@map("bookings")
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}
